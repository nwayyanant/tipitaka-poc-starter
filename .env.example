# ==========================
# Postgres (used by ETL)
# ==========================
# These are the credentials the ETL uses to connect to the Postgres
# container defined in docker-compose. Defaults match docker-compose.yml.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tipitaka
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres


# ==========================
# Weaviate (used by ETL)
# ==========================
# IMPORTANT:
# - When running the ETL INSIDE Docker (docker compose run etl), use the
# service name and internal port:
# WEAVIATE_URL=http://weaviate:8080
# - If you ever run the ETL on your HOST machine (not in Docker), use:
# WEAVIATE_URL=http://localhost:8080
WEAVIATE_URL=http://weaviate:8080
# Logical class name to create/use in Weaviate
CLASS_NAME=TipitakaChunk


# ==========================
# Embedding model for text2vec-transformers (t2v service)
# ==========================
# Choose ONE. LaBSE is strong for Pali but downloads are large and RAM usage
# is higher. The distil model is much lighter and faster.
HF_MODEL_NAME=sentence-transformers/LaBSE
# HF_MODEL_NAME=sentence-transformers/distiluse-base-multilingual-cased-v2


# If you need a private HF model, uncomment and set your token:
# HUGGINGFACE_HUB_TOKEN=hf_********************************


# ==========================
# Data files (paths as seen from the ETL container)
# ==========================
# The ETL container mounts your local ./data directory at /app/data, so keep
# paths relative to /app. The defaults expect:
# - ./data/chunk.csv (required)
# - ./data/windows.csv (optional)
CSV_CHUNKS=data/chunk.csv
CSV_WINDOWS=data/windows.csv


# ==========================
# Column names in your CSVs
# ==========================
# The ETL will try to auto-detect common names, but you can pin them here.
# For chunk.csv: set the main text column (e.g., pali_text or text)
TEXT_COLUMN=pali_text
# For windows.csv: set the window text column if you provide windows.csv
WINDOW_COLUMN=window_text


# ==========================
# ETL behavior
# ==========================
# Controls how many objects to send per Weaviate batch. Tune for speed/memory.
BATCH_SIZE=200


# If true, the ETL will DROP and recreate the Postgres table and Weaviate
# class before loading. Useful for clean re-runs; keep false for incremental.
DROP_AND_RECREATE=false


# ==========================
# (Optional) Multi-tenancy / namespacing (reserved for future use)
# ==========================
# TENANT=
